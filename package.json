{
	"name": "outclass",
	"version": "0.4.0",
	"description": "CSS class composition library",
	"main": "lib/index.js",
	"types": "lib/index.d.ts",
	"type": "module",
	"author": "chielorenz",
	"license": "MIT",
	"files": [
		"lib"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/chielorenz/outclass.git"
	},
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"import": "./lib/index.js"
		}
	},
	"keywords": [
		"class",
		"composable",
		"variants",
		"slots",
		"tailwind",
		"cva",
		"atomic css",
		"utility-first css"
	],
	"scripts": {
		"test": "vitest run",
		"build": "tsup src/index.ts --format esm --dts --clean -d lib",
		"debug": "tsx --inspect repl.ts",
		"bench": "tsx benchmarks/benchmark.ts",
		"bench:competitors": "tsx benchmarks/competitors.ts",
		"lint": "biome lint --write",
		"check": "biome check --write",
		"format": "biome format --write"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@types/node": "^26.0.0",
		"b": "^2.0.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cva": "^0.0.0",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tinybench": "^6.0.2",
		"tsup": "^8.5.1",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9"
	},
	"allowScripts": {
		"esbuild@0.28.1": true,
		"fsevents@2.3.3": true,
		"esbuild@0.27.7": true
	}
}
