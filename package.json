{
  "name": "outclass",
  "version": "0.4.0",
  "description": "CSS class composition library",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "type": "module",
  "files": [
    "lib"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chielorenz/outclass.git"
  },
  "scripts": {
    "dev": "jest --watchAll",
    "test": "jest",
    "debug": "tsx --inspect repl.ts",
    "build": "rm -rf lib/* && tsc"
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    }
  },
  "keywords": [
    "class",
    "composable",
    "variants",
    "slots",
    "tailwind",
    "cva",
    "atomic css",
    "utility-first css"
  ],
  "author": "chielorenz",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.2",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "tsx": "^4.19.4",
    "typescript": "^5.0.4"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "collectCoverage": true,
    "coverageReporters": [
      "text"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "CommonJS",
            "isolatedModules": false,
            "verbatimModuleSyntax": false
          }
        }
      ]
    }
  }
}
